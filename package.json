{
  "name": "iris-hermes-voice",
  "productName": "Iris",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A futuristic Gemini Live voice companion that delegates real work to Hermes.",
  "homepage": "https://github.com/ASHR12/iris#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASHR12/iris.git"
  },
  "bugs": {
    "url": "https://github.com/ASHR12/iris/issues"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && node scripts/run-electron.mjs\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "npm run build && node scripts/run-electron.mjs --prod",
    "start:prod": "node scripts/run-electron.mjs --prod",
    "package:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win --dir",
    "dist:win": "npm run build && electron-builder --win",
    "electron": "node scripts/run-electron.mjs",
    "sidecar": "node scripts/python-command.mjs sidecar",
    "check:python": "node scripts/python-command.mjs check"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^2.10.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "onnxruntime-web": "^1.27.0",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "wait-on": "latest"
  },
  "build": {
    "appId": "app.iris.voice",
    "productName": "Iris",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "dir"
      ]
    }
  }
}
