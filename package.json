{
  "name": "iris-claude-voice",
  "productName": "Iris",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A futuristic Gemini Live voice companion that delegates real work to Claude Code running headless.",
  "homepage": "https://github.com/ASHR12/iris#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASHR12/iris.git"
  },
  "bugs": {
    "url": "https://github.com/ASHR12/iris/issues"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && node scripts/run-electron.mjs\"",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "start": "npm run build && node scripts/run-electron.mjs --prod",
    "start:prod": "node scripts/run-electron.mjs --prod",
    "package:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "electron": "node scripts/run-electron.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@google/genai": "^2.10.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "onnxruntime-web": "^1.27.0",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.181.2",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "vitest": "4.1.10",
    "wait-on": "latest"
  },
  "build": {
    "appId": "app.iris.voice",
    "productName": "Iris",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!electron/**/*.test.mjs",
      "build/icon.png",
      "build/trayTemplate.png",
      "build/trayTemplate@2x.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/personas",
        "to": "personas"
      },
      {
        "from": "resources/project-seed",
        "to": "project-seed"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dir"
      ]
    }
  }
}
