# Optional reference file. Most users should just launch Iris and complete the
# onboarding wizard (gear icon -> Settings -> Run setup wizard), which saves these
# values to ~/.iris/.env for you. Editing files by hand is only for power users.

GEMINI_API_KEY=your_google_ai_studio_key

# Optional overrides
IRIS_USER_NAME=there
IRIS_LOAD_TEST_DATA=false

# Iris reads Hermes's own learned context (~/.hermes/memories/USER.md and
# MEMORY.md) and injects it into Gemini's system prompt so it can resolve vague
# requests and write better Hermes briefs. One shared source of truth, no copying.
# HERMES_HOME=~/.hermes   # override only if Hermes lives somewhere else
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Zephyr
HERMES_API_URL=http://127.0.0.1:8642
API_SERVER_KEY=iris-local-dev

# Optional: full path to the Hermes binary if your packaged GUI app cannot find
# it on PATH. Usually not required when Hermes gateway is already running.
# macOS/Linux example:
# HERMES_BIN=/home/you/.local/bin/hermes
# Windows example:
# HERMES_BIN=C:\\Users\\you\\AppData\\Local\\Programs\\hermes\\hermes.exe
