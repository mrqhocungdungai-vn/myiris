GEMINI_API_KEY=your_google_ai_studio_key

# That's it for chat — Iris talks to you with just the Gemini key above.
# Everything below is optional and mostly for the Claude PO/DEV build pipeline,
# which Iris enables automatically once it detects the Claude Code CLI
# installed (see README's "Claude pipeline (PO -> DEV)" section).

# Optional overrides
IRIS_USER_NAME=there
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Zephyr

# Subscription token — required for the PO role (a stateful Agent SDK
# session). It does NOT reuse your interactive `claude` login. DEV is
# unaffected either way. Generate a one-time subscription OAuth token:
#   claude setup-token
# then paste it here so PO usage bills against your Claude subscription
# instead of the per-token API:
# CLAUDE_CODE_OAUTH_TOKEN=your_setup_token_value
#
# You can also paste it into Settings -> Claude pipeline -> Subscription
# token, which writes this same key for you (the only option in a packaged
# build, where this file lives at ~/.iris/.env). Saving there closes any
# resident PO session so the new token applies on the next PO turn without
# restarting Iris; prior PO context is resumed, not lost.
#
# FOOTGUN: if ANTHROPIC_API_KEY is set anywhere in this environment, it
# outranks CLAUDE_CODE_OAUTH_TOKEN and silently switches usage to metered
# API billing. Iris strips ANTHROPIC_API_KEY from the PO session's own
# environment, but do not set it here unless you intend to pay per token.
# ANTHROPIC_API_KEY is not used by Iris and should be left unset.

# Hands-free "Hey Iris" wake word (on-device ONNX, only listens while asleep).
# Default: on. Set to 0 to disable (also toggleable from Settings).
# IRIS_WAKE_WORD=1

# How long after Gemini's "go_to_sleep" tool call before Iris actually sleeps
# (gives the spoken goodbye time to play). Default: 3000 (ms).
# IRIS_SLEEP_DELAY_MS=3000

# Global hotkey that toggles the Glass HUD overlay (click-through, floats
# over your desktop) from anywhere, even while another app has focus.
# Default: Alt+Space. Electron accelerator syntax (e.g. "Control+Shift+H").
# IRIS_HUD_HOTKEY=Alt+Space

# Iris supports macOS only and refuses to launch on other platforms by
# default. Developer escape hatch for deliberate non-macOS runs (e.g. Linux):
# IRIS_ALLOW_ANY_PLATFORM=1

# Lets Gemini use built-in Google Search for quick facts/lookups. OFF by
# default because it's a BILLED Gemini feature — on a free-tier key, turning
# this on disconnects the Live session immediately with a 1011 quota error.
# Only enable with a paid Gemini key. Accepts 1/true/yes/on (case-insensitive);
# also toggleable from Settings -> Gemini API key, which writes this same key.
# IRIS_ENABLE_GOOGLE_SEARCH=true

# ===== Claude pipeline (PO -> DEV) — optional, auto-detected =====
# Everything from here down only matters if you want the PO/DEV build
# pipeline. Install the Claude Code CLI (`claude --version` works) and Iris
# picks it up automatically — no flag needed to turn it on.

# Directory Claude works in (also scopes its saved sessions):
# IRIS_CLAUDE_CWD=/Users/you/.iris/workspace
# Permission mode for headless DEV runs. Default is bypassPermissions (fully
# autonomous — Claude can run any tool without asking). Set acceptEdits or
# plan for a more restricted worker:
# IRIS_CLAUDE_PERMISSION_MODE=bypassPermissions
# Full path to the claude binary if the packaged GUI app cannot find it:
# macOS/Linux example:
# IRIS_CLAUDE_BIN=/Users/you/.local/bin/claude
# Full path to the openspec CLI if the packaged GUI app cannot find it (used to
# `openspec init` a fresh project — the pipeline's only SDD surface):
# IRIS_OPENSPEC_BIN=/Users/you/.local/bin/openspec

# PREREQUISITE — global skills. The PO/DEV agents run with the globally-installed
# skills in ~/.claude/skills: the OpenSpec workflow skills (openspec-propose,
# openspec-apply-change, openspec-archive-change, ...) and the mattpocock skills
# (grilling, tdd, verify, code-review). Install them once so they are present
# for every project. Settings -> Claude pipeline reports whether the openspec
# CLI and these skills are detected, with a copyable install command for each.
# The agents themselves live in ~/.claude/agents (installed via the "Install
# agents" button).

# How long the PO's live session waits for a voice answer to a mid-turn
# question (AskUserQuestion) before applying its own recommended option.
# Default: 300000 (5 minutes).
# IRIS_PO_QUESTION_TIMEOUT_MS=300000

# Rollback switch: set to 0 to disable the PO live session and fall back to
# the pre-SDK behavior (PO runs one-shot like DEV, no mid-turn questions).
# IRIS_PO_LIVE_SESSION=1

# How long the run holding the execution slot may go without producing a
# progress signal (a tool call, tool result, or activity line) before it is
# terminated automatically and the slot released. This bounds silence, not
# total runtime — a long but healthy run is never killed for being long, and
# a run paused on a PO question (see IRIS_PO_QUESTION_TIMEOUT_MS above) is
# never counted as idle. Default: 1800000 (30 minutes). Rollback: set this
# high enough to never fire (no code change needed).
# IRIS_RUN_IDLE_TIMEOUT_MS=1800000

# How often a chatty run's free-text activity log is flushed to the renderer,
# coalescing bursts of activity lines into one update per interval. Does not
# affect the step timeline (tool_start/tool_end stay realtime) or the idle
# watchdog (heartbeat still fires per line). Default: 150 (ms).
# IRIS_ACTIVITY_EMIT_INTERVAL_MS=150

# Hard deadline for app quit's teardown (closing the Gemini Live socket,
# group-killing DEV subprocesses, closing resident PO sessions) before the
# app force-exits anyway. Default: 8000 (8 seconds).
# IRIS_SHUTDOWN_DEADLINE_MS=8000

# Pre-dispatch review gate: when on (default), every submit_claude_task brief
# is parked for Approve/Edit/Cancel before any Claude tokens are spent. Set to
# 0 to restore the old auto-send behavior (dispatch immediately). Toggleable
# from the UI (PipelineBar) or by voice; whichever value is set here is only
# the startup default — the toggle persists back to this same key.
# IRIS_PROMPT_REVIEW=1

# How long a parked review waits for Approve/Cancel before it is cancelled
# (never auto-approved — auto-sending an unreviewed brief is exactly what the
# gate prevents). Default: 300000 (5 minutes).
# IRIS_PROMPT_REVIEW_TIMEOUT_MS=300000

# Per-role model defaults for the PO/DEV roles (choose from: claude-fable-5,
# claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001). Only used when
# the workstream has no model chosen yet from the UI/voice chip — a workstream
# choice always outranks these. Built-in defaults if unset: PO=claude-fable-5,
# DEV=claude-sonnet-5.
# IRIS_PO_MODEL=claude-fable-5
# IRIS_DEV_MODEL=claude-sonnet-5
